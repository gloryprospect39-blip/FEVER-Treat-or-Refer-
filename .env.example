# FeverGate — Next.js environment variables
# Copy to .env.local and fill in. Never commit real keys.

# Postgres connection string for persisting encounters + patient registry.
# Provisioned automatically when you add the Neon integration on Vercel
# (Vercel Marketplace). Pull it locally with: vercel env pull .env.local
# The app also accepts POSTGRES_URL / DATABASE_URL_UNPOOLED.
# Without it, the app still runs but does not persist data (reports stay empty).
DATABASE_URL=
