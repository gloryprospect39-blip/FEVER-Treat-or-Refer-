# FeverGate — Next.js environment variables
# Copy to .env.local and fill in. Never commit real keys.

# Google AI Studio (Gemini) API key for the AI assistant.
# Create one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
